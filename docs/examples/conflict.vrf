// Example: an explicit conflict — two facts violate a premise.

DOMAIN zoo

FACT Animal_B has flying
FACT Animal_B has swimming

PREMISE fly_xor_swim:
    EXCLUSIVE
        Animal_B has flying
        Animal_B has swimming

CHECK Animal_B

// Expected result:
// CONFLICT  fly_xor_swim
//   zoo.Animal_B has flying    [line 5]
//   zoo.Animal_B has swimming  [line 6]
//   → EXCLUSIVE: at most one may be TRUE
